# Copy to deploy/.env on the box. Real values never enter the repo (D22).
POSTGRES_USER=tieout
POSTGRES_PASSWORD=
POSTGRES_DB=tieout
MINIO_ROOT_USER=tieout
MINIO_ROOT_PASSWORD=

# Named operator bearer tokens "ana:t1,leo:t2" (D32); unset = read-only demo only.
# The public demo includes the lent visitor pair published by DEMO_LOGIN_HINT.
API_OPERATOR_TOKENS=

# The login page's published key hint, "name:token" (D36) — must be one of the
# API_OPERATOR_TOKENS pairs. Deliberately public; leave unset on a private deploy.
DEMO_LOGIN_HINT=

# Cloudflare tunnel token (--profile public); routes tieout.jorgejim.com → web
# and tieout-api.jorgejim.com → api (D37).
TUNNEL_TOKEN=

# Optional: pull CI-built images instead of building on the box.
# TIEOUT_IMAGE=ghcr.io/jorge-j1m/tieout:latest
# TIEOUT_WEB_IMAGE=ghcr.io/jorge-j1m/tieout-web:latest
