{
  "name": "tieout",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @tieout/db db:generate",
    "db:migrate": "pnpm --filter @tieout/db db:migrate",
    "seed": "pnpm --filter @tieout/seed seed",
    "recon": "pnpm --filter @tieout/jobs recon"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.17",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
