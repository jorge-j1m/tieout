# Copy to .env and fill in. Real values never enter the repo (D22).
POSTGRES_USER=tieout
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=tieout
DATABASE_URL=postgres://tieout:change-me-locally@127.0.0.1:5432/tieout
# Tests never touch the database above: with DATABASE_URL set they use an isolated
# "<name>_test" database (auto-created; override via TEST_DATABASE_URL), and with no
# DATABASE_URL at all they fall back to in-memory PGlite — zero setup, nothing to skip.

MINIO_ROOT_USER=tieout
MINIO_ROOT_PASSWORD=change-me-locally
S3_ENDPOINT=http://127.0.0.1:9000

# From your Trigger.dev Cloud project (https://cloud.trigger.dev) — needed for `pnpm dev` only.
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=

# TEST MODE ONLY — never a live key (the adapter refuses non-sk_test_ keys).
# The demo runs against committed fixtures; set STRIPE_LIVE_LANDING=1 to make the
# hourly land-stripe schedule poll the real test-mode API instead.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_LIVE_LANDING=

# Optional: run summaries / failures.
SLACK_WEBHOOK_URL=

# API (apps/api). Operators are named bearer tokens, "ana:token1,leo:token2" (D32);
# unset means the API serves only the read-only demo persona.
API_OPERATOR_TOKENS=
API_PORT=3001

# Web (apps/web). Where the dashboard's server components reach the API (D34),
# and whether the operator session cookie requires https (true in production, D36).
API_BASE_URL=http://127.0.0.1:3001
SESSION_COOKIE_SECURE=false

# Optional: publish a lent operator key as a hint on /login ("name:token" — D36).
# Deliberately public, so not a secret; set it only when the same pair is in
# API_OPERATOR_TOKENS. The public demo lends visitor:under-the-double-rule.
DEMO_LOGIN_HINT=

# LLM triage (D33) — suggestions only, never resolutions; off by default. The
# deterministic pipeline is byte-identical with this disabled. Suggestions are
# cached per break content, and TIEOUT_TRIAGE_MAX_CALLS caps spend per pass.
# Works with ANY OpenAI-compatible provider: point TIEOUT_TRIAGE_BASE_URL at
# its /v1 root and set the matching key + model. Defaults to Anthropic's
# compat endpoint; e.g. OpenAI https://api.openai.com/v1 + gpt-4o, or a local
# Ollama http://127.0.0.1:11434/v1 + llama3.1 with any non-empty key.
TIEOUT_TRIAGE_ENABLED=
TIEOUT_TRIAGE_API_KEY=
TIEOUT_TRIAGE_BASE_URL=https://api.anthropic.com/v1
TIEOUT_TRIAGE_MODEL=claude-opus-4-8
TIEOUT_TRIAGE_MAX_CALLS=25

# Live "Investigate with Claude" (D38) — the streaming, cited conversation on a
# case. Runs in the WEB tier (apps/web route handler), which is the only place
# that touches the LLM key; it reuses TIEOUT_TRIAGE_API_KEY / TIEOUT_TRIAGE_BASE_URL
# above (any OpenAI-compatible provider). Off by default; a signed-in operator
# drives it, and spend is bounded by a daily assistant-turn cap. The api reads
# only ENABLED / ASSISTANT_NAME / DAILY_CAP (the /me flag and budget gate), never
# the key. Deployed default stays sonnet at ~$0.05–0.08/turn.
TIEOUT_INVESTIGATE_ENABLED=
TIEOUT_INVESTIGATE_MODEL=claude-sonnet-5
TIEOUT_INVESTIGATE_ASSISTANT_NAME=Clara
TIEOUT_INVESTIGATE_DAILY_CAP=10
