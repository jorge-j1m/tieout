# Copy to .env and fill in. Real values never enter the repo (D22).
POSTGRES_USER=tieout
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=tieout
DATABASE_URL=postgres://tieout:change-me-locally@127.0.0.1:5432/tieout
# Tests never touch the database above: with DATABASE_URL set they use an isolated
# "<name>_test" database (auto-created; override via TEST_DATABASE_URL), and with no
# DATABASE_URL at all they fall back to in-memory PGlite — zero setup, nothing to skip.

MINIO_ROOT_USER=tieout
MINIO_ROOT_PASSWORD=change-me-locally
S3_ENDPOINT=http://127.0.0.1:9000

# From your Trigger.dev Cloud project (https://cloud.trigger.dev) — needed for `pnpm dev` only.
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=

# TEST MODE ONLY — never a live key. Stage 1 runs against committed fixtures; this stays optional.
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional: run summaries / failures.
SLACK_WEBHOOK_URL=
