{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "SLACK_WEBHOOK_URL",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_PROJECT_REF",
    "STRIPE_SECRET_KEY",
    "UPDATE_GOLDEN",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "@tieout/jobs#test": {
      "dependsOn": ["@tieout/db#test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
