{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "TEST_DATABASE_URL",
    "SLACK_WEBHOOK_URL",
    "TRIGGER_SECRET_KEY",
    "TRIGGER_PROJECT_REF",
    "STRIPE_SECRET_KEY",
    "STRIPE_LIVE_LANDING",
    "API_OPERATOR_TOKENS",
    "API_PORT",
    "API_BASE_URL",
    "SESSION_COOKIE_SECURE",
    "TIEOUT_TRIAGE_ENABLED",
    "TIEOUT_TRIAGE_API_KEY",
    "TIEOUT_TRIAGE_BASE_URL",
    "TIEOUT_TRIAGE_MODEL",
    "TIEOUT_TRIAGE_MAX_CALLS",
    "UPDATE_GOLDEN",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@tieout/web#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {},
    "@tieout/jobs#test": {
      "dependsOn": ["@tieout/db#test"]
    },
    "@tieout/api#test": {
      "dependsOn": ["@tieout/jobs#test"]
    },
    "@tieout/triage#test": {
      "dependsOn": ["@tieout/api#test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
